{
    "compilerOptions": {
        "baseUrl": ".",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "paths": {
            "@/*": [
                "src/lib/*"
            ],
            "@locales": [
                "src/lib/locales"
            ]
        },
        "types": [
            "vitest/globals",
            "src/global.d.ts"
        ]
    },
    "include": [
        "src",
    ],
    "exclude": [
        "node_modules",
    ]
}